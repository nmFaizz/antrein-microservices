# SQLAlchemy database URL.
# Form: postgresql://<user>:<password>@<host>:<port>/<dbname>
# The default postgresql:// scheme uses the psycopg2 driver; you may also be
# explicit with postgresql+psycopg2://...
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# --- Preorder integration (queue -> preorder callback) ---
# All optional. If PREORDER_SERVICE_URL is unset the callback is a no-op.
# Base URL of menu-preorder-service.
PREORDER_SERVICE_URL=http://menu-preorder-service:8000
# Shared HS256 secret (must match menu-preorder-service SECRET_KEY) used to
# mint the service-to-service admin JWT for PATCH /preorders/{id}.
SECRET_KEY=change-me
# user_id claim placed in the minted admin token.
SERVICE_ACCOUNT_ID=00000000-0000-0000-0000-000000000000
