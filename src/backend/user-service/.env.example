# SQLAlchemy database URL.
# Form: postgresql://<user>:<password>@<host>:<port>/<dbname>
# The default postgresql:// scheme uses the psycopg2 driver; you may also be
# explicit with postgresql+psycopg2://...
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Secret key used to sign JWT access tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me

# Optional: defaults shown below.
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
